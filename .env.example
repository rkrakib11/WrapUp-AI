# =============================================================================
# WrapUp AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
#
# Variables prefixed with VITE_ are exposed to the React frontend (Vite).
# All other variables are read by the Python FastAPI backend.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite / React)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# URL of the running backend API (local dev default: http://127.0.0.1:8002)
VITE_BACKEND_URL=http://127.0.0.1:8002
# Stripe publishable key (starts with pk_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
# Optional: WebSocket URL for production streaming (e.g. wss://api.example.com)
# VITE_PROD_BACKEND_WS_URL=wss://api.example.com

# -----------------------------------------------------------------------------
# Backend — App
# -----------------------------------------------------------------------------
APP_NAME=WrapUp AI Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002
APP_LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:8083
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_SECONDS=0.25
JOB_RETRY_BACKOFF_SECONDS=5.0
MAX_JOB_RETRIES=3
HTTP_TIMEOUT_SECONDS=60.0

# -----------------------------------------------------------------------------
# Backend — Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional — required only if you verify JWTs locally instead of via Supabase
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Backend — Transcription (Deepgram)
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key
# Optional: extra Deepgram keys for automatic rotation on rate-limits (comma-separated)
# DEEPGRAM_API_KEYS_EXTRA=key2,key3

# -----------------------------------------------------------------------------
# Backend — Speaker Diarization (pyannote.audio — optional)
# Get a free HuggingFace token at https://hf.co/settings/tokens
# then accept model terms at https://hf.co/pyannote/speaker-diarization-3.1
# Leave empty to fall back to Deepgram's built-in diarization.
# -----------------------------------------------------------------------------
PYANNOTE_AUTH_TOKEN=
DIARIZATION_ENABLED=true
DIARIZATION_MIN_SPEAKERS=1
DIARIZATION_MAX_SPEAKERS=20
DIARIZATION_MERGE_GAP=0.5
DIARIZATION_MIN_SEGMENT_DURATION=0.3

# -----------------------------------------------------------------------------
# Backend — Local Whisper fallback (faster-whisper, runs on the server)
# No API key needed — model is downloaded the first time it is used.
# Set WHISPER_FALLBACK_ENABLED=false to disable local Whisper entirely.
# -----------------------------------------------------------------------------
WHISPER_FALLBACK_ENABLED=true
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_CONFIDENCE_THRESHOLD=0.80

# -----------------------------------------------------------------------------
# Backend — Audio preprocessing
# -----------------------------------------------------------------------------
AUDIO_PREPROCESSING_ENABLED=true

# -----------------------------------------------------------------------------
# Backend — Groq (LLM summarization, Whisper cloud fallback, chatbot)
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_api_key
# Optional: extra Groq keys for automatic rotation on rate-limits (comma-separated)
# GROQ_API_KEYS_EXTRA=gsk_key2,gsk_key3
GROQ_MODEL_SUMMARY=llama-3.3-70b-versatile
GROQ_MODEL_CHAT=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# Backend — RAG / Embeddings
# -----------------------------------------------------------------------------
ENABLE_TRANSFORMER_EMBEDDINGS=true
EMBEDDING_MODEL=intfloat/multilingual-e5-base
RAG_TOP_K=4
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150

# -----------------------------------------------------------------------------
# Backend — Stripe (Payments & Billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PLUS=price_your_plus_price_id
STRIPE_PRICE_BUSINESS=price_your_business_price_id

# -----------------------------------------------------------------------------
# Backend — Storage (Cloudflare R2 or Backblaze B2 — optional)
# Leave blank to use Supabase Storage only.
# -----------------------------------------------------------------------------
# R2_ACCOUNT_ID=your_r2_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=wrapup-audio
# R2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
# R2_PUBLIC_DOMAIN=https://cdn.example.com

# -----------------------------------------------------------------------------
# Backend — Misc
# -----------------------------------------------------------------------------
DATA_DIR=backend/data
FAISS_DIR_NAME=faiss
SUMMARY_TEMPERATURE=0.2
CHAT_TEMPERATURE=0.1
